<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nova_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/nova_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="@string/subtitle"
            android:textColor="@color/nova_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_build_prop"
            android:textColor="@color/nova_text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/buildPropInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/nova_surface"
            android:fontFamily="monospace"
            android:gravity="top"
            android:hint="@string/hint_build_prop"
            android:inputType="textMultiLine"
            android:minLines="6"
            android:padding="12dp"
            android:textColor="@color/nova_text_primary"
            android:textColorHint="@color/nova_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_floating_features"
            android:textColor="@color/nova_text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/floatingFeaturesInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/nova_surface"
            android:fontFamily="monospace"
            android:gravity="top"
            android:hint="@string/hint_floating_features"
            android:inputType="textMultiLine"
            android:minLines="6"
            android:padding="12dp"
            android:textColor="@color/nova_text_primary"
            android:textColorHint="@color/nova_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveProfileButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/nova_accent"
            android:text="@string/action_save_profile"
            android:textColor="@color/nova_text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp"
            android:background="@color/nova_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_target_apps"
            android:textColor="@color/nova_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/targetAppsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="@string/no_target_apps"
            android:textColor="@color/nova_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/chooseAppsButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_choose_apps"
            android:textColor="@color/nova_text_primary"
            app:strokeColor="@color/nova_accent" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
